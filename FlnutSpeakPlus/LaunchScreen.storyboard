                            <constraint firstItem="LaunchBackdropImage" firstAttribute="leading" secondItem="LaunchRootView" secondAttribute="leading" id="backdrop-leading"/>
                            <constraint firstAttribute="trailing" secondItem="LaunchBackdropImage" secondAttribute="trailing" id="backdrop-trailing"/>
                            <constraint firstAttribute="bottom" secondItem="LaunchBackdropImage" secondAttribute="bottom" id="backdrop-bottom"/>

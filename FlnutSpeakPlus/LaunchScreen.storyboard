                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="LaunchLogoGlow" translatesAutoresizingMaskIntoConstraints="NO" id="LaunchLogoGlowImage">
                                <rect key="frame" x="124.5" y="306" width="144" height="144"/>

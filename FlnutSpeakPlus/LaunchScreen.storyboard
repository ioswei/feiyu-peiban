                            <constraint firstItem="LaunchLogoGlowImage" firstAttribute="centerY" secondItem="LaunchSafeArea" secondAttribute="centerY" multiplier="0.88" id="glow-centerY"/>
                            <constraint firstItem="LaunchLogoGlowImage" firstAttribute="width" secondItem="LaunchRootView" secondAttribute="width" multiplier="0.36" id="glow-width-rel"/>
                            <constraint firstItem="LaunchLogoGlowImage" firstAttribute="width" secondItem="LaunchLogoGlowImage" secondAttribute="height" multiplier="1:1" id="glow-aspect"/>
                            <constraint firstItem="LaunchLogoImage" firstAttribute="centerX" secondItem="LaunchSafeArea" secondAttribute="centerX" id="logo-centerX"/>

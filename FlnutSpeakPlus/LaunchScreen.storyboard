                            <constraint firstItem="LaunchLogoImage" firstAttribute="width" secondItem="LaunchRootView" secondAttribute="width" multiplier="0.30" id="logo-width-rel"/>
                            <constraint firstItem="LaunchLogoImage" firstAttribute="width" secondItem="LaunchLogoImage" secondAttribute="height" multiplier="1:1" id="logo-aspect"/>
                            <constraint firstItem="LaunchLogoImage" firstAttribute="width" relation="lessThanOrEqual" constant="132" id="logo-max-width"/>
                            <constraint firstItem="LaunchLogoImage" firstAttribute="width" relation="greaterThanOrEqual" constant="104" id="logo-min-width"/>
